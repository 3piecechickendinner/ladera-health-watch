---
import BaseLayout from '../layouts/BaseLayout.astro';
import ImageSlot from '../components/ImageSlot.astro';
import { VOLUNTEER_FORM_URL, CONTACT_EMAIL } from '../site.config';

const needs = [
  {
    title: 'Public records requests',
    detail: 'Help draft, file, and follow up on records requests with LARMAC, CUSD, and other agencies.',
  },
  {
    title: 'Research',
    detail: 'Background research on environmental records, public health processes, and how similar community efforts have approached this.',
  },
  {
    title: 'Outreach',
    detail: 'Help residents learn about the case reporting form, upcoming meetings, and how to read pesticide notices.',
  },
  {
    title: 'Design',
    detail: 'Ongoing work on this website, printed materials, and clear visual explanations like the map.',
  },
  {
    title: 'Data',
    detail: 'Help organize and aggregate case reports and public records responsibly and anonymously.',
  },
];
---

<BaseLayout
  title="Get Involved"
  description="Volunteer with Ladera Health Watch: records requests, research, outreach, design, and data work."
>
  <section class="mx-auto max-w-3xl px-5 pb-4 pt-10 sm:pt-14">
    <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-gold-700">
      This is a volunteer effort
    </p>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-oak-900 sm:text-5xl">
      Get Involved
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-oak-700">
      Ladera Health Watch runs entirely on volunteer time. However much time you have, an hour or
      an ongoing role, there's a way to help.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-6">
    <a
      href={VOLUNTEER_FORM_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block border border-gold-600 bg-gold-600 px-5 py-3 font-semibold text-paper-50 no-underline hover:bg-gold-700"
    >
      Sign up to volunteer ↗
    </a>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-6">
    <h2 class="font-display text-2xl font-semibold text-oak-900">What we need help with</h2>
    <ul class="mt-4 divide-y divide-oak-700/15 border-y border-oak-700/15">
      {needs.map((need) => (
        <li class="py-4">
          <p class="font-display text-lg font-semibold text-oak-900">{need.title}</p>
          <p class="mt-1 text-base leading-relaxed text-oak-700">{need.detail}</p>
        </li>
      ))}
    </ul>
  </section>

  <section id="about" class="mx-auto max-w-3xl scroll-mt-20 px-5 py-10">
    <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-gold-700">
      Who we are
    </p>
    <h2 class="mt-2 font-display text-2xl font-semibold text-oak-900">About Ladera Health Watch</h2>
    <p class="mt-4 text-base leading-relaxed text-oak-700">
      Ladera Health Watch is a group of concerned parents and residents of Ladera Ranch,
      California. We are entirely volunteer-run: there is no paid staff, no organization behind
      us other than the people who live here.
    </p>

    <div class="mt-5">
      <ImageSlot subject="Ladera Health Watch volunteers or a community meeting" aspectClass="aspect-[16/9]" />
    </div>

    <div class="mt-5 grid gap-4 sm:grid-cols-2">
      <div class="border border-oak-700/25 bg-paper-50 p-5">
        <h3 class="font-display text-lg font-semibold text-oak-900">What this effort is</h3>
        <ul class="mt-3 space-y-2 text-sm leading-relaxed text-oak-700">
          <li>A way to gather and organize self-reported health information from our community.</li>
          <li>A request for a formal, credible analysis from the California Cancer Registry.</li>
          <li>Public records requests to understand pesticide, herbicide, and rodenticide use by LARMAC and CUSD.</li>
          <li>A constructive working relationship with the LARMAC board, including the new resident advisory committee.</li>
        </ul>
      </div>
      <div class="border border-oak-700/25 bg-paper-50 p-5">
        <h3 class="font-display text-lg font-semibold text-oak-900">What this effort is not</h3>
        <ul class="mt-3 space-y-2 text-sm leading-relaxed text-oak-700">
          <li>A claim that a cancer cluster has been found in Ladera Ranch: no such determination has been made.</li>
          <li>A medical, legal, or public health authority: we are residents, not any of those things.</li>
          <li>A dispute with, or campaign against, LARMAC's board: its members are resident volunteers, same as us.</li>
        </ul>
      </div>
    </div>

    <p class="mt-6 border-l-2 border-oak-700/30 pl-4 text-lg leading-relaxed text-oak-900">
      We are asking reasonable questions and requesting reasonable changes. We do not accuse any
      person, product, company, or agency of causing cancer. There is no known environmental
      cause of Ewing sarcoma, and we do not claim otherwise.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-10">
    <h2 class="font-display text-xl font-semibold text-oak-900">Contact us</h2>
    <p class="mt-2 text-base leading-relaxed text-oak-700">
      <a href={`mailto:${CONTACT_EMAIL}`} class="text-fog-700 underline">{CONTACT_EMAIL}</a>
    </p>
    <p class="mt-2 text-sm text-sage-500">
      TODO: this is a temporary address. Replace CONTACT_EMAIL in <code>src/site.config.ts</code>
      with the group's real, monitored inbox before launch.
    </p>
  </section>
</BaseLayout>
