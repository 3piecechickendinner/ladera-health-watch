---
import BaseLayout from '../layouts/BaseLayout.astro';
import { VOLUNTEER_FORM_URL, CONTACT_EMAIL, PETITION_URL } from '../site.config';

const needs = [
  {
    title: 'Public records requests',
    detail: 'Help draft, file, and follow up on records requests with LARMAC, CUSD, and other agencies.',
  },
  {
    title: 'Research',
    detail: 'Background research on environmental records, public health processes, and how similar community efforts have approached this.',
  },
  {
    title: 'Outreach',
    detail: 'Help residents learn about the case reporting form, upcoming meetings, and how to read pesticide notices.',
  },
  {
    title: 'Design',
    detail: 'Ongoing work on this website, printed materials, and clear visual explanations like the map.',
  },
  {
    title: 'Data',
    detail: 'Help organize and aggregate case reports and public records responsibly and anonymously.',
  },
];
---

<BaseLayout
  title="Get Involved"
  description="Volunteer with Ladera Health Watch: records requests, research, outreach, design, and data work."
>
  <section class="mx-auto max-w-3xl px-5 pb-4 pt-10 sm:pt-14">
    <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-gold-700">
      This is a volunteer effort
    </p>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-oak-900 sm:text-5xl">
      Get Involved
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-oak-700">
      Ladera Health Watch runs entirely on volunteer time. However much time you have, an hour or
      an ongoing role, there's a way to help.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-6">
    <a
      href={VOLUNTEER_FORM_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-block border border-gold-600 bg-gold-600 px-5 py-3 font-semibold text-paper-50 no-underline hover:bg-gold-700"
    >
      Sign up to volunteer ↗
    </a>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-6">
    <div class="border border-oak-700/25 bg-paper-50 p-6">
      <h2 class="font-display text-xl font-semibold text-oak-900">Sign the petition</h2>
      <p class="mt-2 text-base leading-relaxed text-oak-700">
        Residents within our group have started a petition asking LARMAC to suspend certain
        pesticide products and adopt further Integrated Pest Management practices. We're sharing
        it because residents asked us to, not because Ladera Health Watch has independently
        verified every claim it makes. Signing it, like everything here, is voluntary.
      </p>
      <a
        href={PETITION_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block border border-gold-600 bg-gold-600 px-5 py-3 font-semibold text-paper-50 no-underline hover:bg-gold-700"
      >
        Sign the petition ↗
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-6">
    <h2 class="font-display text-2xl font-semibold text-oak-900">What we need help with</h2>
    <ul class="mt-4 divide-y divide-oak-700/15 border-y border-oak-700/15">
      {needs.map((need) => (
        <li class="py-4">
          <p class="font-display text-lg font-semibold text-oak-900">{need.title}</p>
          <p class="mt-1 text-base leading-relaxed text-oak-700">{need.detail}</p>
        </li>
      ))}
    </ul>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-10">
    <h2 class="font-display text-xl font-semibold text-oak-900">Contact us</h2>
    <p class="mt-2 text-base leading-relaxed text-oak-700">
      <a href={`mailto:${CONTACT_EMAIL}`} class="text-fog-700 underline">{CONTACT_EMAIL}</a>
    </p>
  </section>
</BaseLayout>
