---
import BaseLayout from '../layouts/BaseLayout.astro';
import Ledger from '../components/Ledger.astro';
import ActionCard from '../components/ActionCard.astro';
import { SURVEY_FORM_URL, FACEBOOK_GROUP_URL, PETITION_URL, SITE_TAGLINE } from '../site.config';

const compactKnow = [
  'Self-reported Ewing sarcoma diagnoses in Ladera Ranch children in 2007, 2013, 2017, 2021, 2022, 2023, and 2024',
  'Regular pesticide, herbicide, and rodenticide applications in common areas, per LARMAC notices',
  'A California Cancer Registry analysis was requested in May 2026; results are pending',
];

const compactDontKnow = [
  'Whether cancer rates in Ladera Ranch exceed state baselines',
  'What caused any individual case',
  'Whether any environmental factor is involved',
];
---

<BaseLayout
  title="Ladera Health Watch"
  description="Community information about reported Ewing sarcoma cases in Ladera Ranch: what we know, what we don't, and how to help."
>
  <section class="mx-auto max-w-2xl px-5 pb-8 pt-12 sm:pb-10 sm:pt-16">
    <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-gold-700">
      {SITE_TAGLINE}
    </p>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-oak-900 sm:text-5xl">
      What's happening in Ladera Ranch, and what we're doing about it.
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-oak-700">
      Since 2007, Ladera Ranch families have self-reported Ewing sarcoma diagnoses in children,
      most recently in 2021–2024, along with other cancer cases. We've requested a state registry
      analysis, filed pesticide-use records requests, and are working with LARMAC on a resident
      advisory committee.
    </p>
    <p class="mt-4 border-l-2 border-oak-700/30 pl-4 text-lg leading-relaxed text-oak-900">
      No cancer cluster has been officially determined in Ladera Ranch. We do not know what
      caused these cancers, and we do not yet have confirmation that cancer rates here are
      higher than the rest of California.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-10 sm:py-14">
    <Ledger knowItems={compactKnow} dontKnowItems={compactDontKnow} compact />
    <p class="mt-4 text-base leading-relaxed text-oak-700">
      Read the full ledger and timeline on <a href="/what-we-know/" class="text-fog-700 underline">What We Know</a>.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-10 sm:py-14">
    <h2 class="font-display text-2xl font-semibold text-oak-900">Three ways to help right now</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <ActionCard
        href={SURVEY_FORM_URL}
        title="Report a case"
        description="If you or a family member received a cancer diagnosis while living in Ladera Ranch, your report helps build an accurate community registry. Takes 5 to 10 minutes; any question can be skipped."
        icon="survey"
        ctaLabel="Report a case ↗"
        external
      />
      <ActionCard
        href={FACEBOOK_GROUP_URL}
        title="Get updates"
        description="Join our Facebook group for the latest news, meeting recaps, and records-request results."
        icon="updates"
        external
      />
      <ActionCard
        href="/get-involved/"
        title="Volunteer"
        description="Help with records requests, research, outreach, design, or data, however much time you have."
        icon="volunteer"
      />
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-5 pt-6 pb-20 sm:pt-10 sm:pb-28">
    <div class="border border-oak-700/25 bg-paper-50 p-6">
      <div class="flex items-center gap-3">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-7 w-7 shrink-0 text-gold-700"
          aria-hidden="true"
        >
          <path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
        </svg>
        <h2 class="font-display text-xl font-semibold text-oak-900">Sign the petition</h2>
      </div>
      <p class="mt-3 text-base leading-relaxed text-oak-700">
        Residents within our group have also started a petition asking LARMAC to suspend certain
        pesticide products. We're sharing it because residents asked us to, not because we've
        independently verified every claim it makes.
      </p>
      <a
        href={PETITION_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-4 inline-block border border-gold-600 bg-gold-600 px-5 py-3 font-semibold text-paper-50 no-underline hover:bg-gold-700"
      >
        Sign the petition ↗
      </a>
    </div>
  </section>
</BaseLayout>
