---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('news')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFormatter = new Intl.DateTimeFormat('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="News & Updates"
  description="Updates from Ladera Health Watch and press coverage of self-reported cancer cases and pesticide questions in Ladera Ranch."
>
  <section class="mx-auto max-w-3xl px-5 pb-4 pt-10 sm:pt-14">
    <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-gold-700">
      Stay current
    </p>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-oak-900 sm:text-5xl">
      News &amp; Updates
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-oak-700">
      Updates from the group, plus press coverage. To add a post, a volunteer just adds one
      markdown file. See the README.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-5 py-6">
    <ul class="divide-y divide-oak-700/15 border-y border-oak-700/15">
      {posts.map((post) => (
        <li class="py-6">
          <p class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-sage-500">
            <time datetime={post.data.date.toISOString()}>{dateFormatter.format(post.data.date)}</time>
            {post.data.type === 'press' && (
              <span class="border border-fog-700/40 px-1.5 py-0.5 text-fog-700">
                Press{post.data.sourceName ? ` · ${post.data.sourceName}` : ''}
              </span>
            )}
          </p>
          <h2 class="mt-2 font-display text-xl font-semibold text-oak-900">
            <a
              href={post.data.type === 'press' && post.data.externalUrl ? post.data.externalUrl : `/news/${post.id}/`}
              target={post.data.type === 'press' ? '_blank' : undefined}
              rel={post.data.type === 'press' ? 'noopener noreferrer' : undefined}
              class="no-underline hover:text-fog-700 hover:underline"
            >
              {post.data.title}
            </a>
          </h2>
          <p class="mt-2 text-base leading-relaxed text-oak-700">{post.data.summary}</p>
          <a
            href={`/news/${post.id}/`}
            class="mt-2 inline-block text-sm font-semibold text-fog-700 underline"
          >
            Read more →
          </a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>
