---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thanks"
  description="You're signed up for Ladera Health Watch updates."
>
  <section class="mx-auto max-w-2xl px-5 py-16 text-center sm:py-24">
    <p class="font-display text-sm font-semibold uppercase tracking-[0.14em] text-gold-700">
      Thank you
    </p>
    <h1 class="mt-3 font-display text-4xl font-semibold leading-tight text-oak-900 sm:text-5xl">
      You're on the list.
    </h1>
    <p class="mt-6 text-lg leading-relaxed text-oak-700">
      We'll only email you with real updates: research, records, meetings, and ways to help.
    </p>
    <a href="/" class="mt-8 inline-block text-base font-semibold text-fog-700 underline">
      Back to the homepage
    </a>
  </section>
</BaseLayout>
