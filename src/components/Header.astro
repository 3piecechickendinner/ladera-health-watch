---
import { SITE_NAME, NAV_LINKS } from '../site.config';

const currentPath = Astro.url.pathname;
---

<header class="border-b border-oak-700/20 bg-paper-50">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-5 py-4">
    <a href="/" class="flex items-baseline gap-2 no-underline">
      <span class="font-display text-xl font-semibold text-oak-900 sm:text-2xl">{SITE_NAME}</span>
    </a>

    <nav class="hidden md:block" aria-label="Primary">
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-semibold">
        {NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-oak-700 no-underline hover:text-fog-700 hover:underline"
              aria-current={currentPath === link.href ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none rounded border border-oak-700/30 px-3 py-2 text-sm font-semibold text-oak-700 marker:content-none">
        Menu
      </summary>
      <nav
        class="absolute right-0 z-10 mt-2 w-56 border border-oak-700/25 bg-paper-50 p-3 shadow-sm"
        aria-label="Primary"
      >
        <ul class="space-y-1 text-sm font-semibold">
          {NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="block rounded px-2 py-2 text-oak-700 no-underline hover:bg-sage-100"
                aria-current={currentPath === link.href ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </details>
  </div>
</header>
