---
import { FORMSPREE_ENDPOINT, SITE_NAME } from '../site.config';
---

<form action={FORMSPREE_ENDPOINT} method="POST" class="flex flex-col gap-3 sm:flex-row">
  <label for="email-capture-input" class="sr-only">Email address</label>
  <input
    id="email-capture-input"
    type="email"
    name="email"
    required
    placeholder="you@example.com"
    class="min-w-0 flex-1 border border-oak-700/30 bg-paper-50 px-4 py-3 text-base text-oak-900 placeholder:text-sage-500"
  />
  <button
    type="submit"
    class="border border-gold-600 bg-gold-600 px-5 py-3 font-semibold text-paper-50 hover:bg-gold-700 sm:shrink-0"
  >
    Sign up for email updates
  </button>

  {/* Tags this submission so it's identifiable in a Formspree account shared across projects. */}
  <input type="hidden" name="source" value={SITE_NAME} />
  <input type="hidden" name="_subject" value={`New email signup: ${SITE_NAME}`} />

  {/* Formspree honeypot: real visitors never fill this in, bots often do. */}
  <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" aria-hidden="true" />
</form>
