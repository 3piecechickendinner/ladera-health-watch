---
interface Props {
  href: string;
  title: string;
  description: string;
  icon: 'survey' | 'updates' | 'volunteer' | 'petition';
  external?: boolean;
  ctaLabel?: string;
}

const { href, title, description, icon, external = false, ctaLabel } = Astro.props;

const icons: Record<Props['icon'], string> = {
  survey:
    'M8 4h8a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm2-1h4a1 1 0 0 1 1 1v1H9V4a1 1 0 0 1 1-1ZM9 12h6M9 16h6M9 8h3',
  updates:
    'M4 6h16v11a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V6Zm0 0 8 7 8-7',
  volunteer:
    'M12 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 9a7 7 0 0 1 14 0',
  petition:
    'M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z',
};
---

<a
  href={href}
  target={external ? '_blank' : undefined}
  rel={external ? 'noopener noreferrer' : undefined}
  class="group flex flex-col gap-3 border border-oak-700/25 bg-paper-50 p-6 no-underline transition-colors hover:border-gold-600"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.5"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="h-8 w-8 text-oak-700"
    aria-hidden="true"
  >
    <path d={icons[icon]} />
  </svg>
  <span class="font-display text-lg font-semibold text-oak-900 group-hover:text-fog-700">
    {title}
  </span>
  <span class="text-sm leading-relaxed text-oak-700">{description}</span>
  <span class="mt-auto text-sm font-semibold text-gold-700">
    {ctaLabel ?? (external ? 'Open link ↗' : 'Go →')}
  </span>
</a>
