---
// The site's signature visual device: a two-column dossier-style ledger.
// Used compact on Home and in full on /what-we-know/.
interface Props {
  knowItems: string[];
  dontKnowItems: string[];
  compact?: boolean;
}

const { knowItems, dontKnowItems, compact = false } = Astro.props;
---

<div class="border border-oak-700/25 bg-paper-50">
  <div class="grid md:grid-cols-2">
    <div class="p-5 md:p-7 border-b md:border-b-0 md:border-r border-oak-700/25">
      <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-oak-700">
        <span class="inline-block h-2.5 w-2.5 bg-gold-600" aria-hidden="true"></span>
        What we know
      </p>
      <ul class="mt-4 space-y-3">
        {knowItems.map((item) => (
          <li class="border-l-2 border-gold-600/50 pl-3 text-[0.98rem] leading-relaxed text-oak-900">
            {item}
          </li>
        ))}
      </ul>
    </div>
    <div class="p-5 md:p-7">
      <p class="flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-oak-700">
        <span class="inline-block h-2.5 w-2.5 rounded-full border-2 border-fog-700" aria-hidden="true"></span>
        What we don't know
      </p>
      <ul class="mt-4 space-y-3">
        {dontKnowItems.map((item) => (
          <li class="border-l-2 border-fog-700/40 pl-3 text-[0.98rem] leading-relaxed text-oak-900">
            {item}
          </li>
        ))}
      </ul>
    </div>
  </div>
  {!compact && (
    <p class="border-t border-oak-700/25 px-5 py-3 text-sm text-sage-500 md:px-7">
      No cancer cluster has been officially determined in Ladera Ranch. Formal cancer cluster findings are rare, even in communities that pursue them for years.
    </p>
  )}
</div>
