---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_NAME, SITE_DESCRIPTION, SITE_URL, FACEBOOK_GROUP_URL } from '../site.config';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Extra JSON-LD schema object(s) for this page (e.g. Article on a news
   * post). The site-wide Organization schema below is always included. */
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const { title, description = SITE_DESCRIPTION, ogImage = '/og.png', structuredData } = Astro.props;

const pageTitle = title === SITE_NAME ? title : `${title} · ${SITE_NAME}`;
// Astro.site (set in astro.config.mjs) is the production domain, so these
// stay correct even though the page is served from localhost in dev.
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site);
const ogImageAlt = `${SITE_NAME}: a volunteer effort by Ladera Ranch parents and residents.`;

// Site-wide Organization schema, present on every page so search engines and
// AI answer engines have one consistent, structured description of who's
// behind the site. Individual pages can add more via the structuredData prop.
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: SITE_NAME,
  url: SITE_URL,
  description: SITE_DESCRIPTION,
  sameAs: [FACEBOOK_GROUP_URL],
};

const jsonLdSchemas = [
  organizationSchema,
  ...(structuredData ? (Array.isArray(structuredData) ? structuredData : [structuredData]) : []),
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook: this matters a lot since most traffic arrives via shared FB links -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content={SITE_NAME} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Public+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Zilla+Slab:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    {jsonLdSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body class="flex min-h-screen flex-col font-body">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-oak-900 focus:px-4 focus:py-2 focus:text-paper-100"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
